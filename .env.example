# Copiar a .env para correr local. En Render se setean en el dashboard / render.yaml.
PORT=10000

# MODO SEGURO: true = el cerebro solo atiende a ALLOWED_TESTERS (el resto se
# registra en la BD sin respuesta). Pasar a false cuando Clarck apruebe el guion.
SAFE_MODE=true
TEST_TRIGGER=ping kipi

# Cerebro IA (Semana 2). Sin la key, el bot funciona pero no responde (solo registra).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Números SOLO dígitos con código de país (Perú = 51...), separados por coma.
# Testers que el cerebro atiende aunque SAFE_MODE=true:
ALLOWED_TESTERS=51999888777
# Número de control: recibe avisos de leads/handoffs y usa los comandos "kipi ...":
NOTIFY_NUMBER=51999888777
